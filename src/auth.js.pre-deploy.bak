/**
 * auth.js — Authentication & RBAC middleware
 * Supports: Azure AD SSO (production) + local username/password (dev)
 * Drop into agent-deploy-platform/src/auth.js
 */
const crypto = require("crypto");
const Database = require("better-sqlite3");
const path     = require("path");

// ─── ROLES ────────────────────────────────────────────────────────────────────
const ROLES = {
  ADMIN:     "admin",      // deploy all, destroy, manage users, view all costs
  DEVELOPER: "developer",  // deploy own agents, view own deployments + costs
  VIEWER:    "viewer",     // read-only: marketplace, dashboard, health status
};

// What each role can do
const PERMISSIONS = {
  [ROLES.ADMIN]:     ["deploy", "destroy", "view_all", "manage_users", "view_costs", "download_iac", "view_audit"],
  [ROLES.DEVELOPER]: ["deploy", "view_own", "download_iac", "view_own_costs"],
  [ROLES.VIEWER]:    ["view_all"],
};

// ─── USER STORE (SQLite) ──────────────────────────────────────────────────────
let _udb;
function getUserDb() {
  if (_udb) return _udb;
  _udb = new Database(process.env.USER_DB_PATH || path.join(__dirname, "../data/users.db"));
  _udb.pragma("journal_mode = WAL");
  _udb.exec(`
    CREATE TABLE IF NOT EXISTS users (
      id         TEXT PRIMARY KEY,
      email      TEXT UNIQUE NOT NULL,
      name       TEXT NOT NULL,
      role       TEXT NOT NULL DEFAULT 'viewer',
      password_hash TEXT,
      azure_oid  TEXT UNIQUE,
      created_at TEXT DEFAULT (datetime('now')),
      last_login TEXT,
      is_active  INTEGER DEFAULT 1
    );

    CREATE TABLE IF NOT EXISTS sessions (
      token      TEXT PRIMARY KEY,
      user_id    TEXT NOT NULL,
      expires_at TEXT NOT NULL,
      created_at TEXT DEFAULT (datetime('now'))
    );

    CREATE TABLE IF NOT EXISTS audit_log (
      id         INTEGER PRIMARY KEY AUTOINCREMENT,
      user_id    TEXT,
      user_email TEXT,
      action     TEXT NOT NULL,
      resource   TEXT,
      details    TEXT,
      ip         TEXT,
      timestamp  TEXT DEFAULT (datetime('now'))
    );

    -- Create default admin if no users exist
    INSERT OR IGNORE INTO users (id, email, name, role, password_hash)
    VALUES (
      'admin-default',
      'admin@aiplatform.local',
      'Platform Admin',
      'admin',
      '${hashPassword("Admin@123!")}'
    );
  `);
  return _udb;
}

// ─── PASSWORD HASHING ─────────────────────────────────────────────────────────
function hashPassword(password) {
  const salt = crypto.randomBytes(16).toString("hex");
  const hash = crypto.pbkdf2Sync(password, salt, 100000, 64, "sha512").toString("hex");
  return `${salt}:${hash}`;
}

function verifyPassword(password, stored) {
  const [salt, hash] = stored.split(":");
  const verify = crypto.pbkdf2Sync(password, salt, 100000, 64, "sha512").toString("hex");
  return verify === hash;
}

// ─── SESSION TOKENS ───────────────────────────────────────────────────────────
function createSession(userId) {
  const token     = crypto.randomBytes(32).toString("hex");
  const expiresAt = new Date(Date.now() + 8 * 60 * 60 * 1000).toISOString(); // 8 hours
  getUserDb().prepare(
    "INSERT INTO sessions (token, user_id, expires_at) VALUES (?, ?, ?)"
  ).run(token, userId, expiresAt);
  return token;
}

function validateSession(token) {
  if (!token) return null;
  const session = getUserDb().prepare(
    "SELECT s.*, u.email, u.name, u.role, u.is_active FROM sessions s JOIN users u ON s.user_id = u.id WHERE s.token = ? AND s.expires_at > datetime('now')"
  ).get(token);
  if (!session || !session.is_active) return null;
  return session;
}

function destroySession(token) {
  getUserDb().prepare("DELETE FROM sessions WHERE token = ?").run(token);
}

// ─── AZURE AD TOKEN VALIDATION ────────────────────────────────────────────────
async function validateAzureToken(bearerToken) {
  if (!process.env.AZURE_AD_TENANT_ID || !process.env.AZURE_AD_CLIENT_ID) return null;

  try {
    // In production: use @azure/msal-node to validate the JWT
    // Here we decode without full signature validation (add jwks-rsa for production)
    const parts   = bearerToken.split(".");
    if (parts.length !== 3) return null;
    const payload = JSON.parse(Buffer.from(parts[1], "base64").toString());

    // Check token is for our app
    if (payload.aud !== process.env.AZURE_AD_CLIENT_ID) return null;
    if (payload.exp < Date.now() / 1000) return null;

    // Find or create user from Azure AD claims
    const db    = getUserDb();
    let   user  = db.prepare("SELECT * FROM users WHERE azure_oid = ?").get(payload.oid);

    if (!user) {
      // Auto-provision user from Azure AD
      const email = payload.upn || payload.email || `${payload.oid}@azuread`;
      const role  = getDefaultRoleForEmail(email);
      const id    = `azuread-${payload.oid}`;
      db.prepare("INSERT OR IGNORE INTO users (id, email, name, role, azure_oid) VALUES (?, ?, ?, ?, ?)")
        .run(id, email, payload.name || email, role, payload.oid);
      user = db.prepare("SELECT * FROM users WHERE id = ?").get(id);
    }

    // Update last login
    db.prepare("UPDATE users SET last_login = datetime('now') WHERE id = ?").run(user.id);
    return user;
  } catch (e) {
    return null;
  }
}

function getDefaultRoleForEmail(email) {
  const adminDomains  = (process.env.ADMIN_EMAIL_DOMAINS  || "").split(",").filter(Boolean);
  const devDomains    = (process.env.DEV_EMAIL_DOMAINS    || "").split(",").filter(Boolean);
  if (adminDomains.some(d => email.endsWith(d))) return ROLES.ADMIN;
  if (devDomains.some(d => email.endsWith(d)))   return ROLES.DEVELOPER;
  return ROLES.VIEWER;
}

// ─── MIDDLEWARE ───────────────────────────────────────────────────────────────

/**
 * requireAuth — attach user to req, redirect to login if not authenticated
 * Usage: app.get('/protected', requireAuth, handler)
 */
function requireAuth(req, res, next) {
  // Check session cookie
  const token = req.cookies?.session;
  if (token) {
    const session = validateSession(token);
    if (session) {
      req.user = { id: session.user_id, email: session.email, name: session.name, role: session.role };
      return next();
    }
  }

  // Check Bearer token (for API calls)
  const bearer = req.headers.authorization?.replace("Bearer ", "");
  if (bearer) {
    const session = validateSession(bearer);
    if (session) {
      req.user = { id: session.user_id, email: session.email, name: session.name, role: session.role };
      return next();
    }
  }

  // API requests get 401
  if (req.path.startsWith("/api/")) {
    return res.status(401).json({ error: "Authentication required" });
  }

  // Browser requests get redirected to login
  res.redirect(`/login?redirect=${encodeURIComponent(req.path)}`);
}

/**
 * requireRole — check user has the right role
 * Usage: app.delete('/api/deployments/:id', requireAuth, requireRole('admin'), handler)
 */
function requireRole(...allowedRoles) {
  return (req, res, next) => {
    if (!req.user) return res.status(401).json({ error: "Not authenticated" });
    if (!allowedRoles.includes(req.user.role)) {
      auditLog(req.user, "PERMISSION_DENIED", req.path, { required: allowedRoles });
      return res.status(403).json({ error: `Requires role: ${allowedRoles.join(" or ")}` });
    }
    next();
  };
}

/**
 * requirePermission — check user has a specific permission
 */
function requirePermission(permission) {
  return (req, res, next) => {
    if (!req.user) return res.status(401).json({ error: "Not authenticated" });
    const perms = PERMISSIONS[req.user.role] || [];
    if (!perms.includes(permission) && !perms.includes("view_all")) {
      return res.status(403).json({ error: `Missing permission: ${permission}` });
    }
    next();
  };
}

// ─── AUDIT LOG ────────────────────────────────────────────────────────────────
function auditLog(user, action, resource, details = {}) {
  try {
    getUserDb().prepare(
      "INSERT INTO audit_log (user_id, user_email, action, resource, details, ip) VALUES (?, ?, ?, ?, ?, ?)"
    ).run(user?.id, user?.email, action, resource, JSON.stringify(details), details.ip || null);
  } catch (e) { console.error("Audit log failed:", e.message); }
}

function auditMiddleware(action) {
  return (req, res, next) => {
    auditLog(req.user, action, req.path, { method: req.method, body: req.body, ip: req.ip });
    next();
  };
}

// ─── USER MANAGEMENT ─────────────────────────────────────────────────────────
const userManager = {
  list() {
    return getUserDb().prepare(
      "SELECT id, email, name, role, created_at, last_login, is_active FROM users ORDER BY created_at DESC"
    ).all();
  },

  create({ email, name, role, password }) {
    const { v4: uuidv4 } = require("uuid");
    const id = uuidv4();
    getUserDb().prepare(
      "INSERT INTO users (id, email, name, role, password_hash) VALUES (?, ?, ?, ?, ?)"
    ).run(id, email, name, role || ROLES.VIEWER, hashPassword(password || "ChangeMe@123"));
    return id;
  },

  updateRole(userId, newRole) {
    getUserDb().prepare("UPDATE users SET role = ? WHERE id = ?").run(newRole, userId);
  },

  deactivate(userId) {
    getUserDb().prepare("UPDATE users SET is_active = 0 WHERE id = ?").run(userId);
    getUserDb().prepare("DELETE FROM sessions WHERE user_id = ?").run(userId);
  },

  getAuditLog(limit = 100) {
    return getUserDb().prepare(
      "SELECT * FROM audit_log ORDER BY timestamp DESC LIMIT ?"
    ).all(limit);
  },
};

// ─── LOGIN ROUTE HANDLER ──────────────────────────────────────────────────────
async function handleLogin(req, res) {
  const { email, password } = req.body;
  const db   = getUserDb();
  const user = db.prepare("SELECT * FROM users WHERE email = ? AND is_active = 1").get(email);

  if (!user || !user.password_hash || !verifyPassword(password, user.password_hash)) {
    auditLog({ email }, "LOGIN_FAILED", "/login", { ip: req.ip });
    return res.status(401).json({ error: "Invalid email or password" });
  }

  const token = createSession(user.id);
  db.prepare("UPDATE users SET last_login = datetime('now') WHERE id = ?").run(user.id);
  auditLog(user, "LOGIN_SUCCESS", "/login", { ip: req.ip });

  res.cookie("session", token, {
    httpOnly: true,
    secure:   process.env.NODE_ENV === "production",
    sameSite: "lax",
    maxAge:   8 * 60 * 60 * 1000, // 8 hours
  });

  res.json({ ok: true, user: { id: user.id, email: user.email, name: user.name, role: user.role } });
}

function handleLogout(req, res) {
  const token = req.cookies?.session;
  if (token) { destroySession(token); auditLog(req.user, "LOGOUT", "/logout"); }
  res.clearCookie("session");
  res.redirect("/login");
}

module.exports = {
  ROLES, PERMISSIONS,
  requireAuth, requireRole, requirePermission,
  auditLog, auditMiddleware,
  handleLogin, handleLogout,
  validateAzureToken,
  userManager,
  createSession, validateSession,
};
