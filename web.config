<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <handlers>
      <add name="iisnode" path="server.js" verb="*" modules="iisnode"/>
    </handlers>
    <rewrite>
      <rules>
        <rule name="NodeInspector" patternSyntax="ECMAScript" stopProcessing="true">
          <match url="^server.js\/debug[\/]?" />
        </rule>
        <rule name="StaticContent">
          <action type="Rewrite" url="public{REQUEST_URI}"/>
        </rule>
        <rule name="DynamicContent">
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="True"/>
          </conditions>
          <action type="Rewrite" url="server.js"/>
        </rule>
      </rules>
    </rewrite>
    <security>
      <requestFiltering>
        <hiddenSegments>
          <remove segment="bin"/>
        </hiddenSegments>
        <requestLimits maxAllowedContentLength="52428800" />
      </requestFiltering>
    </security>
    <httpErrors existingResponse="PassThrough" />

    <!-- Disable dynamic compression for audio/binary — prevents IIS corrupting audio streams -->
    <urlCompression doStaticCompression="true" doDynamicCompression="false" />
    <httpCompression>
      <dynamicTypes>
        <remove mimeType="audio/*" />
        <remove mimeType="application/octet-stream" />
      </dynamicTypes>
    </httpCompression>

    <iisnode
      watchedFiles="web.config;*.js"
      node_env="production"
      loggingEnabled="true"
      logDirectory="iisnode"
      asyncCompletionThreadCount="4"
      initialRequestBufferSize="65536"
      maxRequestBufferSize="65536"
      maxConcurrentRequestsPerProcess="1024"
    />
  </system.webServer>
</configuration>
